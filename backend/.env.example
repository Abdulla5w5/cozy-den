# ---- Server ----
NODE_ENV=development
PORT=4000

# Comma-separated list of allowed frontend origins (NO wildcard in production).
CORS_ORIGINS=http://localhost:5173

# ---- Database ----
# Either provide DATABASE_URL, or the individual PG* vars below.
DATABASE_URL=postgres://cozyden:cozyden@localhost:5432/cozyden
# PGHOST=localhost
# PGPORT=5432
# PGUSER=cozyden
# PGPASSWORD=cozyden
# PGDATABASE=cozyden

# ---- Auth (staff dashboard) ----
# Generate a long random value, e.g.  openssl rand -hex 48
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=8h
# Set to true when served over HTTPS so the auth cookie is marked Secure.
COOKIE_SECURE=false

# Optional comma-separated allow-list of staff emails permitted to sign in.
# Leave empty to let the staff_users table alone govern access.
# STAFF_ALLOWED_EMAILS=staff@cozyden.local,manager@cozyden.local

# ---- Booking business rules ----
# Flat table reservation fee added to every booking, in cents.
TABLE_FEE_CENTS=500

# ---- Payment provider ----
# Which provider implementation to load. Only "mock" ships in phase 1.
# Swap to "stripe" (etc.) later WITHOUT touching booking logic.
PAYMENT_PROVIDER=mock
# PAYMENT_API_KEY=      # supplied later for the real provider

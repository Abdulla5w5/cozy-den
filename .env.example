# Copy to .env and fill in. .env is gitignored — never commit real secrets.
# Generate strong values:  openssl rand -hex 16   (password)
#                          openssl rand -hex 48   (jwt secret, >=32 chars)

# Postgres password (used by db + backend DATABASE_URL).
POSTGRES_PASSWORD=change-me

# JWT signing secret — MUST be >=32 chars in production or the app won't start.
JWT_SECRET=change-me-to-a-long-random-string

# Google Sign-In client id (public, not secret). Same value used by the
# frontend build arg. Leave blank to disable the Google button.
GOOGLE_CLIENT_ID=

# Allowed frontend origin(s) for CORS. In production use your real URL/domain.
CORS_ORIGINS=http://localhost:8080

# Set to true only when served over HTTPS (marks the session cookie Secure).
COOKIE_SECURE=false

# Comma-separated staff emails that may access the dashboard.
STAFF_ALLOWED_EMAILS=staff@cozyden.local

# HTTP port the site is served on (production droplet sets 80).
HTTP_PORT=8080

# Redis (shared rate-limit store)
REDIS_PASSWORD=change-me
# REDIS_URL=redis://:PASSWORD@10.x.x.x:6379

# Postgres TLS (production)
DB_SSL=off
# DB_CERT_DIR=/opt/pgcerts

# Host port for the published DB/Redis (prod leaves defaults)
DB_PORT=5432
REDIS_PORT=6379
